    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "output_items = []\n\nfor item in _items:\n    text = item[\"json\"][\"result\"][\"text\"]\n    \n    phone = \"\"\n    address = \"\"\n    order_items = []\n    ordered_items_text = \"\"\n    \n    # توحيد الفواصل: هنحول أي سطر جديد أو فاصلة لنقطة عشان نقسم الجمل صح\n    normalized_text = text.replace('\\n', '.').replace('،', '.')\n    parts = normalized_text.split('.')\n    \n    for part in parts:\n        cleaned_part = part.strip()\n        \n        # 1. استخراج رقم الموبايل\n        if \"رقم الموبايل:\" in cleaned_part:\n            phone = cleaned_part.split(\"رقم الموبايل:\")[1].strip()\n            \n        # 2. استخراج العنوان\n        elif \"العنوان:\" in cleaned_part:\n            address = cleaned_part.split(\"العنوان:\")[1].strip()\n            \n        # 3. استخراج تفاصيل الأوردر (لو مكتوبة في نفس السطر)\n        elif \"تفاصيل الأوردر:\" in cleaned_part:\n            ordered_items_text = cleaned_part.split(\"تفاصيل الأوردر:\")[1].strip()\n            \n        # 4. استخراج الأوردر (لو لسه بيكتبها في سطور بتبدأ بـ شرطة)\n        elif cleaned_part.startswith('-'):\n            item_text = cleaned_part.replace('-', '').strip()\n            order_items.append(item_text)\n\n    # لو لقاها بنظام الشرط، يجمعهم\n    if order_items and not ordered_items_text:\n        ordered_items_text = \" + \".join(order_items)\n\n    # بنضيف الخانات الجديدة جوة الـ JSON الأساسي\n    item[\"json\"][\"ordered_items\"] = ordered_items_text\n    item[\"json\"][\"phone\"] = phone\n    item[\"json\"][\"location\"] = address\n    \n    output_items.append(item)\n\nreturn output_items"
      },
